Cell["\<\
The decision tree is consistent with mobbing being more symmetric, while \
transiting birds exhibit more of an even split.\
\>", "Text",
 CellChangeTimes->{{3.987684792839797*^9, 3.9876848293534727`*^9}, {
  3.987685024416161*^9, 
  3.9876850325567408`*^9}},ExpressionUUID->"f5cb7e52-00f2-4bee-a693-\
532993dcb18e"],

Cell[CellGroupData[{

Cell["Herd-level only", "Subsubsection",
 CellChangeTimes->{{3.987966173629586*^9, 
  3.987966180095845*^9}},ExpressionUUID->"515a6f37-f9c5-40d0-b4af-\
3e36ac5741bd"],

Cell["\<\
[This is not that insightful, because the individual-level CV changes more \
dramatically with mobbing. See next section.]\
\>", "Text",
 CellChangeTimes->{{3.987966497974304*^9, 
  3.9879665043808117`*^9}},ExpressionUUID->"fe8f13bb-2826-4ab2-a3af-\
dba8500dc895"],

Cell["\<\
Using only the population-level CV with an even split (f=1/2), the data are \
consistent with splits:\
\>", "Text",
 CellChangeTimes->{{3.9879659423561707`*^9, 
  3.987965988860862*^9}},ExpressionUUID->"6734ddb3-df24-4829-9727-\
6b4886f25a80"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CVherdCs", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"16", " ", 
       SuperscriptBox["\[ExponentialE]", 
        FractionBox[
         SubsuperscriptBox["c", "S", "2"], "4"]], " ", 
       RowBox[{"(", 
        RowBox[{"4", "+", 
         RowBox[{"f", " ", 
          SubsuperscriptBox["c", "S", "2"]}]}], ")"}]}], 
      RowBox[{"\[Pi]", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"4", " ", 
           SuperscriptBox["\[ExponentialE]", 
            FractionBox[
             SubsuperscriptBox["c", "S", "2"], "8"]], " ", 
           RowBox[{"(", 
            RowBox[{"1", "-", "f"}], ")"}]}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"4", "+", 
             SubsuperscriptBox["c", "S", "2"]}], ")"}], "f", " ", 
           RowBox[{"BesselI", "[", 
            RowBox[{"0", ",", 
             FractionBox[
              SubsuperscriptBox["c", "S", "2"], "8"]}], "]"}]}], "+", 
          RowBox[{"f", " ", 
           SubsuperscriptBox["c", "S", "2"], " ", 
           RowBox[{"BesselI", "[", 
            RowBox[{"1", ",", 
             FractionBox[
              SubsuperscriptBox["c", "S", "2"], "8"]}], "]"}]}]}], ")"}], 
        "2"]}]], "-", "1"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.940541991940102*^9, 3.940542020127756*^9}, {
   3.940694721683755*^9, 3.9406947459551277`*^9}, {3.940695900957597*^9, 
