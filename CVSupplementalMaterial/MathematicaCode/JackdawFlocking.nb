    RowBox[{"\[Pi]", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"4", " ", 
         SuperscriptBox["\[ExponentialE]", 
          FractionBox[
           SubsuperscriptBox["c", "S", "2"], "8"]], " ", 
         RowBox[{"(", 
          RowBox[{"1", "-", "f"}], ")"}]}], "+", 
        RowBox[{"f", " ", 
         RowBox[{"BesselI", "[", 
          RowBox[{"1", ",", 
           FractionBox[
            SubsuperscriptBox["c", "S", "2"], "8"]}], "]"}], " ", 
         SubsuperscriptBox["c", "S", "2"]}], "+", 
        RowBox[{"f", " ", 
         RowBox[{"BesselI", "[", 
          RowBox[{"0", ",", 
           FractionBox[
            SubsuperscriptBox["c", "S", "2"], "8"]}], "]"}], " ", 
         RowBox[{"(", 
          RowBox[{"4", "+", 
           SubsuperscriptBox["c", "S", "2"]}], ")"}]}]}], ")"}], 
      "2"]}]]}]]], "Output",
